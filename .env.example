# ==============================================================================
# .env.example — Rapsodia / Th1eros.io
# ==============================================================================

# BANCO DE DADOS — RUNTIME (Pooler :6543 — Transaction mode)
# Usado pela API em execução normal (dotnet run)
DB_HOST_MIGRATIONS=YOUR_PROJECT_REF.supabase.co
DB_PORT_MIGRATIONS=5432
DB_NAME=postgres
DB_USER_MIGRATIONS=postgres
DB_PASSWORD=YOUR_PASSWORD

# RUNTIME — Transaction Pooler
ConnectionStrings__DefaultConnection="Host=YOUR_POOLER_HOST;Port=6543;Database=postgres;Username=postgres.YOUR_PROJECT_REF;Password=YOUR_PASSWORD;Ssl Mode=Require;Trust Server Certificate=true;No Reset On Close=true;"
UID=
GID=

# BANCO DE DADOS — MIGRATIONS (Session mode :5432)
# Usado pelo dotnet ef database update / dotnet ef migrations add
DB_PORT_MIGRATIONS_SESSION=5432
DB_USER_MIGRATIONS_SESSION=postgres.YOUR_PROJECT_REF

# JWT — Autenticação
# JWT_KEY deve ter no mínimo 32 caracteres para HMAC-SHA256
JWT_KEY=YOUR_SECURE_JWT_KEY_MIN_32_CHARS
JWT_ISSUER=Rapsodia
JWT_AUDIENCE=Rapsodia_Clients

# ASPNETCORE
ASPNETCORE_ENVIRONMENT=Development
FIELD_ENCRYPTION_KEY=YOUR_FIELD_ENCRYPTION_KEY
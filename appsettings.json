{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Information"
    }
  },
  "AllowedHosts": "*",
  "Environment": "Development",
  "ConnectionStrings": {
    "DefaultConnection": "Host={POOLER_HOST};Port={DB_PORT_RUNTIME};Database={DB_NAME};Username={DB_USER_MIGRATIONS};Password={DB_PASSWORD};Ssl Mode=Require;Trust Server Certificate=true;No Reset On Close=true;"
  },
  "Jwt": {
    "Key": "JWT_KEY",
    "Issuer": "JWT_ISSUER",
    "Audience": "JWT_AUDIENCE"
  },
  "DatabaseConfig": {
    "Migrations": {
      "Host": "DB_HOST_MIGRATIONS",
      "Port": "DB_PORT_MIGRATIONS",
      "Password": "DB_PASSWORD"
    }
  },
  "Security": {
    "FieldEncryptionKey": "FIELD_ENCRYPTION_KEY"
  }
}